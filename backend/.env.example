# API
API_HOST=0.0.0.0
API_PORT=8000
# Structured logs: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG
# Comma-separated; include every dev origin (e.g. if Next uses 3001 when 3000 is busy)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Redis / Celery (match docker-compose port)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Adapters
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
VOICE_AGENT_API_KEY=
VOICE_AGENT_BASE_URL=
EXA_API_KEY=

# Optional path overrides (defaults are relative to backend package roots)
# DATA_DIR=
# SKILLS_DIR=
